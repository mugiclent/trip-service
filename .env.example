NODE_ENV=development
PORT=8092

# Docker image (used by docker-compose.yml)
DOCKER_USERNAME=yourdockerhubusername
IMAGE_TAG=latest

# Database — credentials only; host/port default to pgbouncer:6432
DB_USER=trip_svc
DB_PASSWORD=
DB_NAME=katisha_trips
# DB_HOST=pgbouncer  (default)
# DB_PORT=6432       (default)

# Migrations — direct connection (bypass pgbouncer, for Prisma CLI only)
DIRECT_DATABASE_URL=postgresql://trip_svc:PASSWORD@db:5432/katisha_trips
SHADOW_DATABASE_URL=postgresql://trip_svc:PASSWORD@db:5432/katisha_trips_shadow

# Redis — password only; host/port default to redis:6379
REDIS_PASSWORD=
# REDIS_HOST=redis   (default)
# REDIS_PORT=6379    (default)

# RabbitMQ — credentials only; host/port default to rabbitmq:5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=
# RABBITMQ_HOST=rabbitmq  (default)
# RABBITMQ_PORT=5672      (default)

# Payment service — internal URL for wallet balance pre-flight check
PAYMENT_SERVICE_URL=http://payment-svc:8098
